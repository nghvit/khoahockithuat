# =============================================
#   Support HR — Environment Variables
#   Sao chép file này thành .env và điền key
# =============================================

# ── Gemini API Keys ───────────────────────────
# Lấy tại: https://aistudio.google.com/app/apikey
VITE_GEMINI_API_KEY_1=your_gemini_api_key_1
VITE_GEMINI_API_KEY_2=your_gemini_api_key_2
VITE_GEMINI_API_KEY_3=your_gemini_api_key_3
VITE_GEMINI_API_KEY_4=your_gemini_api_key_4

# ── Firebase ──────────────────────────────────
# Lấy tại: https://console.firebase.google.com → Project Settings → Your apps
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── App Info ──────────────────────────────────
VITE_APP_NAME=Support HR
VITE_APP_VERSION=1.0.0
